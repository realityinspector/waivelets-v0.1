entrypoint = "main.py"
modules = ["python-3.10:v18-20230807-322e88b", "postgresql-16"]

[nix]
channel = "stable-23_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main_apr18.py"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8000
externalPort = 8008
exposeLocalhost = true

[[ports]]
localPort = 11385
externalPort = 8099
exposeLocalhost = true

[[ports]]
localPort = 25057
externalPort = 5173
exposeLocalhost = true
